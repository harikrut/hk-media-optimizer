# A set of files you probably don't want in your WordPress.org distribution.
# Directories
/.git
/.github
/.wordpress-org
/bin
/docs
/node_modules
# DO NOT EXCLUDE /vendor — Action Scheduler is bundled into the release.

# Files
.*
CHANGELOG.md
CODE_OF_CONDUCT.md
composer.json
composer.lock
CONTRIBUTING.md
CREDITS.md
LICENSE.md
package.json
package-lock.json
phpcs.xml
README.md
SECURITY.md
